	"devDependencies": {
		"@biomejs/biome": "2.4.8",
		"@types/bun": "^1.3.10",
		"@types/react": "~19.2.14",
		"@types/react-dom": "~19.1.7",
		"typescript": "5.9.3"
	},
	"expo": {
		"doctor": {
			"reactNativeDirectoryCheck": {
				"listUnknownPackages": false,
				"exclude": [
					"@gorhom/portal"
				]
			}
		},
		"install": {
			"exclude": [
				"react-native-get-random-values"
			]
		}
	}
}
